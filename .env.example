# ============================================================================
# Lumitra Self-Host — Environment Variables
# Copy this file to .env and adjust as needed.
# ============================================================================

# ─── General ────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Override if using managed Postgres (Supabase, Neon, RDS, etc.)
# STORAGE_BRAIN_DATABASE_URL=postgres://user:pass@host:5432/storagebrain
# DATA_BRAIN_DATABASE_URL=postgres://user:pass@host:5432/databrain

# ─── Storage Brain ──────────────────────────────────────────────────────
STORAGE_BRAIN_PORT=3000
STORAGE_BRAIN_ADMIN_API_KEY=admin-dev-key
URL_SIGNING_SECRET=dev-signing-secret

# S3 / MinIO settings
S3_BUCKET=storage-brain
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Override for managed S3 (AWS, DigitalOcean Spaces, Backblaze B2, etc.)
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ─── Data Brain ─────────────────────────────────────────────────────────
DATA_BRAIN_PORT=3001
DATA_BRAIN_ADMIN_API_KEY=admin-dev-key

# ─── MinIO Console ──────────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
